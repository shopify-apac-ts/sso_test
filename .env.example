# Change to your actual Render URL after deployment
BASE_URL=http://localhost:3000

# Secret for session encryption (must be changed to a random value in production)
SESSION_SECRET=change-me-in-production

# Client credentials used in Shopify's SSO provider settings
# Register these same values in Shopify
CLIENT_ID=my-sso-client-id
CLIENT_SECRET=my-sso-client-secret

# Shopify app secret — used to verify Shopify session tokens (HS256) in the /userinfo endpoint
# Must match the API secret key of your Shopify app
SHOPIFY_API_SECRET=your-shopify-api-secret-key
